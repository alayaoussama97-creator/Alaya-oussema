rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny (Must be first as per guidelines)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation helper
    function isValidVideo(data) {
      return data.keys().hasAll(['title', 'url', 'type', 'createdAt', 'userId']) 
        && data.keys().size() <= 14
        && data.title is string && data.title.size() <= 200
        && data.url is string && data.url.size() <= 4096
        && data.type in ['local', 'external', 'youtube']
        && data.createdAt is number
        && (data.userId == (request.auth != null ? request.auth.uid : 'guest_user'))
        && (!('tags' in data) || (data.tags is list && data.tags.size() <= 12))
        && (!('storagePath' in data) || (data.storagePath is string && data.storagePath.size() <= 1024))
        && (!('thumbnail' in data) || (data.thumbnail is string && data.thumbnail.size() <= 4096))
        && (!('duration' in data) || (data.duration is string && data.duration.size() <= 50))
        && (!('isLocalOnly' in data) || data.isLocalOnly is bool);
    }

    // Validation helper for updating a video
    function isValidVideoUpdate(data, existingData) {
      return data.keys().hasAll(['title', 'url', 'type', 'createdAt', 'userId']) 
        && data.keys().size() <= 14
        && data.title is string && data.title.size() <= 200
        && data.url is string && data.url.size() <= 4096
        && data.type in ['local', 'external', 'youtube']
        && data.createdAt is number
        && data.userId == existingData.userId
        && (!('tags' in data) || (data.tags is list && data.tags.size() <= 12))
        && (!('storagePath' in data) || (data.storagePath is string && data.storagePath.size() <= 1024))
        && (!('thumbnail' in data) || (data.thumbnail is string && data.thumbnail.size() <= 4096))
        && (!('duration' in data) || (data.duration is string && data.duration.size() <= 50))
        && (!('isLocalOnly' in data) || data.isLocalOnly is bool);
    }

    match /videos/{videoId} {
      allow read: if true; // Public library
      allow create: if isValidVideo(request.resource.data);
      allow update: if (isOwner(resource.data.userId) || resource.data.userId == 'guest_user' || (isSignedIn() && request.auth.token.email == 'alayaoussama97@gmail.com')) && isValidVideoUpdate(request.resource.data, resource.data);
      allow delete: if isOwner(resource.data.userId) || resource.data.userId == 'guest_user' || (isSignedIn() && request.auth.token.email == 'alayaoussama97@gmail.com'); 
    }

    match /chat_sessions/{sessionId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      match /messages/{messageId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data.userId == request.auth.uid;
      }
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'commentsCount']))
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    match /network_events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Simulation writes or admin
    }

    match /threat_alerts/{alertId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /direct_messages/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/direct_messages/$(chatId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/direct_messages/$(chatId)).data.participants;
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
